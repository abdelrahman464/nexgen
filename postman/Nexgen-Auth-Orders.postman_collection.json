        {
          "name": "Apple — verify receipt",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"receiptData\": \"MIITuwYJKoZIhvcNAQcCoIITrDCCE6gCAQExCzAJBgUrDgMCGgUAMIIDXAYJKoZIhvcNAQcBoIIDTQSCA0kxggNFMAoCAQgCAQEEAhYAMAoCARQ...PASTE_BASE64_RECEIPT_FROM_appStoreReceiptURL_HERE\",\n  \"productId\": \"com.nexgen.academy.package.monthly\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/orders/apple/verifyReceipt",
            "description": "Called by the iOS app immediately after StoreKit returns a successful transaction.\n\n- `receiptData` (required): base64 of `appStoreReceiptURL` contents from StoreKit.\n- `productId` (optional): if you know which IAP triggered this, pass it so the server picks the right transaction from the receipt. Must match `appleProductId` on a `Course` / `Package` / `CoursePackage` document.\n\nIdempotent: re-sending the same receipt returns the existing order id."
          }
        },
        {
          "name": "Webhook — Apple",
          "request": {
