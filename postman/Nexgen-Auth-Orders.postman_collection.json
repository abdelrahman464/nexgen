              { "key": "Stripe-Signature", "value": "t=1715000000,v1=PUT_VALID_HMAC_SHA256_HERE" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"evt_1Test\",\n  \"object\": \"event\",\n  \"type\": \"checkout.session.completed\",\n  \"data\": {\n    \"object\": {\n      \"id\": \"cs_test_123\",\n      \"client_reference_id\": \"507f1f77bcf86cd799439012\",\n      \"customer_email\": \"john.doe@example.com\",\n      \"amount_total\": 4999,\n      \"metadata\": {\n        \"type\": \"course\",\n        \"couponName\": null\n      }\n    }\n  }\n}",
