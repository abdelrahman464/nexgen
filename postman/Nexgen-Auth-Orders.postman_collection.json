{
  "info": {
    "name": "Nexgen — Auth & Orders",
    "description": "Postman collection for Nexgen API. Set `baseUrl` first. Run **Auth → Login**; the test script auto-populates the `token` collection variable, so all bearer requests will work afterwards. Replace example IDs (`courseId`, `packageId`, `coursePackageId`, `orderId`, `userId`) with real Mongo IDs from your DB.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000/api/v1" },
    { "key": "token", "value": "" },
    { "key": "userId", "value": "507f1f77bcf86cd799439011" },
    { "key": "courseId", "value": "507f1f77bcf86cd799439012" },
    { "key": "packageId", "value": "507f1f77bcf86cd799439013" },
    { "key": "coursePackageId", "value": "507f1f77bcf86cd799439014" },
    { "key": "orderId", "value": "507f1f77bcf86cd799439015" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"P@ssw0rd123\",\n  \"passwordConfirm\": \"P@ssw0rd123\",\n  \"country\": \"Palestine\",\n  \"invitationKey\": \"defaultKey\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/signup",
            "description": "Validators (`utils/validators/authValidator.js`) require `name`, `email` (unique), `password` (8-32 chars matching `passwordConfirm`), `country`. `invitationKey` is optional and must exist in `MarketLog.invitationKeys` if provided.\n\nIf you want to upload `profileImg` / `coverImg` / `signatureImage` / `idDocuments`, switch Body → form-data and add file fields with those names (handled by `uploadImages` multer middleware)."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json && json.token) {",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    if (json.data && json.data._id) {",
                  "      pm.collectionVariables.set('userId', json.data._id);",
                  "    }",
                  "    console.log('token + userId saved to collection variables');",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"P@ssw0rd123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "Test script auto-saves `token` and `userId` to collection variables so every other request works."
          }
        },
        {
          "name": "Google OAuth — start",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/auth/google",
            "description": "Browser redirect flow — open in a browser, not Postman."
          }
        },
        {
          "name": "Google OAuth — callback",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/auth/google/callback?code=GOOGLE_AUTH_CODE&state=STATE",
            "description": "Called by Google after user consent; not invoked manually."
          }
        },
        {
          "name": "Google mobile",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"eyJhbGciOiJSUzI1NiIsImtpZCI6IjEyMzQ1Njc4OTAiLCJ0eXAiOiJKV1QifQ.PASTE_GOOGLE_ID_TOKEN_FROM_MOBILE_SDK_HERE.signature\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/google/mobile",
            "description": "`idToken` is the Google ID token returned by the iOS / Android Google Sign-In SDK."
          }
        },
        {
          "name": "Forgot password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/forgotPassword",
            "description": "Sends a 6-digit reset code to the user's email."
          }
        },
        {
          "name": "Verify reset code",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resetCode\": \"123456\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/verifyResetCode",
            "description": "Lookup is by hashed reset code (no email needed). Valid for 10 minutes."
          }
        },
        {
          "name": "Reset password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"newPassword\": \"NewP@ssw0rd456\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/resetPassword",
            "description": "Requires `verifyResetCode` to have succeeded first (sets `passwordResetVerified=true`)."
          }
        },
        {
          "name": "Verify email",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"123456\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/verifyEmail",
            "description": "Lookup is by hashed email-verification code (no email needed)."
          }
        },
        {
          "name": "Resend email code",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/resendEmailCode",
            "description": "Only works if the account exists and `emailVerified === false`."
          }
        },
        {
          "name": "Get me (current user)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/auth/getMe"
          }
        },
        {
          "name": "Admin — issue user token",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/admin/issue-user-token",
            "description": "Admin-only impersonation/support endpoint. `userId` must be a valid Mongo ObjectId."
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Purchase for user (admin manual grant)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"course\",\n  \"id\": \"{{courseId}}\",\n  \"userId\": \"{{userId}}\",\n  \"isPaid\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/orders/purchaseForUser",
            "description": "Manually create an order for a user. `type` ∈ `course` | `package` | `coursePackage`; `id` is the corresponding item id; `isPaid` is a boolean.\n\nNote: in `routes/OrderRoute.js` the `protect`, `allowedTo('admin')` and `purchaseForUserValidator` middlewares are currently commented out — confirm before exposing in production."
          }
        },
        {
          "name": "Create unpaid order (free course)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "PUT",
            "header": [],
            "url": "{{baseUrl}}/orders/createUnPaidOrder/{{courseId}}",
            "description": "Enroll the current user in a free course (price must be 0)."
          }
        },
        {
          "name": "List orders",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/orders?page=1&limit=10&sort=-createdAt&isPaid=true",
              "host": ["{{baseUrl}}"],
              "path": ["orders"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "sort", "value": "-createdAt" },
                { "key": "isPaid", "value": "true" },
                { "key": "userId", "value": "{{userId}}", "disabled": true, "description": "Admin-only: filter by another user's id" },
                { "key": "startDate", "value": "2026-01-01", "disabled": true },
                { "key": "endDate", "value": "2026-12-31", "disabled": true },
                { "key": "day", "value": "2026-05-10", "disabled": true }
              ]
            },
            "description": "Regular users always see only their own orders. Admins (or the user's invitor) can pass `userId` to filter by another user."
          }
        },
        {
          "name": "Get order by id",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/orders/{{orderId}}"
          }
        },
        {
          "name": "Statistics (admin)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/orders/statistics",
              "host": ["{{baseUrl}}"],
              "path": ["orders", "statistics"],
              "query": [
                { "key": "courseId", "value": "{{courseId}}", "disabled": true },
                { "key": "packageId", "value": "{{packageId}}", "disabled": true },
                { "key": "coursePackageId", "value": "{{coursePackageId}}", "disabled": true }
              ]
            },
            "description": "Optional product filter via one of `courseId` / `packageId` / `coursePackageId`."
          }
        },
        {
          "name": "By month (admin)",
