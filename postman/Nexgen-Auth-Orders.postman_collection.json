            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"txn_id\": \"PLI-TXN-1234567890\",\n  \"status\": \"completed\",\n  \"order_number\": \"COURSE_507f1f77bcf86cd799439012_1715000000000\",\n  \"order_name\": \"course\",\n  \"order_description\": \"507f1f77bcf86cd799439012|john.doe@example.com|null\",\n  \"amount\": \"49.99\",\n  \"currency\": \"USDT_TRX\",\n  \"verify_hash\": \"PUT_VALID_SHA1_HMAC_HERE\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/orders/webhook/plisio",
            "description": "Real Plisio webhooks are signed with `verify_hash = HMAC-SHA1(JSON_without_verify_hash, PLISIO_SECRET_KEY)`. Without a valid hash, the server rejects with 400. `order_description` must be `\"<itemId>|<userEmail>|<couponName>\"` and `order_name` ∈ `course` | `package` | `coursepackage`."
          }
